{
  "name": "facebook-scraper-api",
  "main": "src/index.js",
  "compatibility_date": "2024-05-12",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "vars": {
    "WORKER_VERSION": "1.0.0",
    "ENVIRONMENT": "production"
  }
}
