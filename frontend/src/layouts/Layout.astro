---
import '../styles/global.css';
import { getUser } from '../lib/auth';
import { createSupabaseServerClient } from '../lib/supabase';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Scraped Facebook Posts | Data Inspector", 
  description = "Browse and inspect scraped Facebook group posts stored in Supabase with a clean, modern interface." 
} = Astro.props;

const { user } = await getUser(Astro);

let unreadCount = 0;
let userEmail = '';
let userFullName = '';
let userAvatar = '';
let userInitials = '';

if (user) {
  userEmail = user.email || '';
  userFullName = user.user_metadata?.full_name || 'User';
  userAvatar = user.user_metadata?.avatar_url || '';
  userInitials = userFullName ? userFullName.charAt(0).toUpperCase() : userEmail.charAt(0).toUpperCase();

  const supabase = createSupabaseServerClient(Astro);
  const { count } = await supabase
    .from('notifications')
    .select('*', { count: 'exact', head: true })
    .eq('user_id', user.id)
    .eq('is_read', false);
  unreadCount = count || 0;
}
---

<!doctype html>
<html lang="en" class="h-full bg-slate-50 text-slate-800 antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		<slot name="head" />
	</head>
	<body class="flex min-h-full flex-col font-['Inter']" data-user-id={user?.id || ''}>
		<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-sm">
			<div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
				<a href="/" id="nav-logo" class="flex items-center gap-2 font-bold text-slate-900 text-lg tracking-tight">
					<svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
					</svg>
					<span>FB Data Inspector</span>
				</a>
				<nav class="flex items-center gap-4 sm:gap-6">
					<a href="/" id="nav-home" class="font-medium text-slate-600 text-sm hover:text-blue-600 transition-colors">Home</a>
					<a href="/search" id="nav-search" class="flex items-center gap-1 rounded-lg bg-slate-100 px-3 py-1.5 font-medium text-slate-700 text-sm hover:bg-blue-50 hover:text-blue-600 transition-colors">
						<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
						</svg>
						<span class="hidden sm:inline">Search & Filter</span>
						<span class="sm:hidden">Search</span>
					</a>
          {user && (
            <>
              <a href="/alerts" class="font-medium text-slate-600 text-sm hover:text-blue-600 transition-colors">Alerts</a>
              <a href="/notifications" id="nav-notifications" class="relative font-medium text-slate-600 hover:text-blue-600 transition-colors flex items-center justify-center h-8 w-8 rounded-full hover:bg-slate-100">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                {unreadCount > 0 && (
                  <span id="notification-badge" class="absolute top-0 right-0 block h-4 w-4 rounded-full bg-red-500 text-[10px] font-bold text-white flex items-center justify-center transform translate-x-1 -translate-y-1">
                    {unreadCount > 99 ? '99+' : unreadCount}
                  </span>
                )}
              </a>
              <div class="relative inline-block text-left" id="profile-menu-container">
                <button type="button" id="profile-menu-button" class="flex items-center justify-center h-10 w-10 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 overflow-hidden transition-shadow" aria-haspopup="true" aria-expanded="false">
                  {userAvatar ? (
                    <img src={userAvatar} alt={userFullName} class="h-full w-full object-cover" />
                  ) : (
                    <div class="h-full w-full bg-[#2563eb] text-white flex items-center justify-center font-bold text-lg">
                      {userInitials}
                    </div>
                  )}
                </button>

                <div id="profile-dropdown" class="absolute right-0 mt-2 w-[260px] origin-top-right rounded-[14px] bg-white shadow-[0_8px_30px_rgb(0,0,0,0.12)] ring-1 ring-black ring-opacity-5 focus:outline-none opacity-0 invisible translate-y-[-10px] transition-all duration-200 z-50 pointer-events-none" role="menu" aria-orientation="vertical" aria-labelledby="profile-menu-button" tabindex="-1">
                  <div class="p-4 border-b border-slate-100 flex flex-col items-center">
                    <div class="h-16 w-16 rounded-full overflow-hidden mb-3 shadow-sm border border-slate-100">
                      {userAvatar ? (
                        <img src={userAvatar} alt={userFullName} class="h-full w-full object-cover" />
                      ) : (
                        <div class="h-full w-full bg-[#2563eb] text-white flex items-center justify-center font-bold text-2xl">
                          {userInitials}
                        </div>
                      )}
                    </div>
                    <p class="text-[15px] font-bold text-slate-800 truncate w-full text-center">{userFullName}</p>
                    <p class="text-[13px] text-gray-500 truncate w-full text-center mt-0.5">{userEmail}</p>
                  </div>
                  <div class="p-2" role="none">
                    <a href="/logout" class="block w-full text-center px-4 py-2.5 text-sm font-semibold text-white bg-red-500 hover:bg-red-600 rounded-lg transition-colors" role="menuitem" tabindex="-1">Logout</a>
                  </div>
                </div>
              </div>
            </>
          )}
				</nav>
			</div>
		</header>

		<main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 mx-auto w-full max-w-7xl">
			<slot />
		</main>

		<footer class="border-t border-slate-200 bg-white py-6">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-xs text-slate-500">
				<p>Facebook Scraper Data Inspector &bull; Powered by Astro, Tailwind CSS & Supabase</p>
			</div>
		</footer>

    <script>
      import { supabase } from '../lib/supabase';
      
      const body = document.body;
      const userId = body.getAttribute('data-user-id');
      
      if (userId) {
        supabase.channel('layout-notifications')
          .on(
            'postgres_changes',
            { event: 'INSERT', schema: 'public', table: 'notifications', filter: `user_id=eq.${userId}` },
            (payload) => {
              const badge = document.getElementById('notification-badge');
              if (badge) {
                let count = parseInt(badge.innerText.replace('+', '')) || 0;
                count++;
                badge.innerText = count > 99 ? '99+' : count.toString();
                badge.classList.remove('hidden');
              } else {
                const nav = document.getElementById('nav-notifications');
                if (nav) {
                  const span = document.createElement('span');
                  span.id = 'notification-badge';
                  span.className = 'absolute top-0 right-0 block h-4 w-4 rounded-full bg-red-500 text-[10px] font-bold text-white flex items-center justify-center transform translate-x-1 -translate-y-1';
                  span.innerText = '1';
                  nav.appendChild(span);
                }
              }
            }
          ).subscribe();
      }

      // Profile Dropdown Interactivity
      const profileContainer = document.getElementById('profile-menu-container');
      const profileButton = document.getElementById('profile-menu-button');
      const profileDropdown = document.getElementById('profile-dropdown');
      
      if (profileContainer && profileButton && profileDropdown) {
        let isOpen = false;
        
        const openMenu = () => {
          isOpen = true;
          profileDropdown.classList.remove('opacity-0', 'invisible', 'translate-y-[-10px]', 'pointer-events-none');
          profileDropdown.classList.add('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
          profileButton.setAttribute('aria-expanded', 'true');
        };
        
        const closeMenu = () => {
          isOpen = false;
          profileDropdown.classList.add('opacity-0', 'invisible', 'translate-y-[-10px]', 'pointer-events-none');
          profileDropdown.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
          profileButton.setAttribute('aria-expanded', 'false');
        };

        const toggleMenu = (e) => {
          e.stopPropagation();
          isOpen ? closeMenu() : openMenu();
        };

        profileButton.addEventListener('click', toggleMenu);
        
        // Desktop hover logic
        profileContainer.addEventListener('mouseenter', () => {
          if (window.matchMedia('(min-width: 768px)').matches) openMenu();
        });
        profileContainer.addEventListener('mouseleave', () => {
          if (window.matchMedia('(min-width: 768px)').matches) closeMenu();
        });

        // Click outside to close
        document.addEventListener('click', (e) => {
          if (isOpen && !profileContainer.contains(e.target)) {
            closeMenu();
          }
        });

        // Escape key to close
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen) {
            closeMenu();
            profileButton.focus();
          }
        });
      }
    </script>
	</body>
</html>
