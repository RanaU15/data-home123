---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Scraped Facebook Posts | Data Inspector", 
  description = "Browse and inspect scraped Facebook group posts stored in Supabase with a clean, modern interface." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full bg-slate-50 text-slate-800 antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="flex min-h-full flex-col font-['Inter']">
		<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-sm">
			<div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
				<a href="/" id="nav-logo" class="flex items-center gap-2 font-bold text-slate-900 text-lg tracking-tight">
					<svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
					</svg>
					<span>FB Data Inspector</span>
				</a>
				<nav class="flex items-center gap-6">
					<a href="/" id="nav-home" class="font-medium text-slate-600 text-sm hover:text-blue-600 transition-colors">Home</a>
					<a href="/search" id="nav-search" class="flex items-center gap-1 rounded-lg bg-slate-100 px-3 py-1.5 font-medium text-slate-700 text-sm hover:bg-blue-50 hover:text-blue-600 transition-colors">
						<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
						</svg>
						<span>Search & Filter</span>
					</a>
				</nav>
			</div>
		</header>

		<main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 mx-auto w-full max-w-7xl">
			<slot />
		</main>

		<footer class="border-t border-slate-200 bg-white py-6">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-xs text-slate-500">
				<p>Facebook Scraper Data Inspector &bull; Powered by Astro, Tailwind CSS & Supabase</p>
			</div>
		</footer>
	</body>
</html>
