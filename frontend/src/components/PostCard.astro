---
import { parseImages, formatDate, type Post } from '../lib/supabase';

interface Props {
  post: Post;
}

const { post } = Astro.props;
// Never use screenshots, only parse actual uploaded images
const images = parseImages(post.images, null);
const firstImage = images[0] || null;
const imageCount = images.length;
const truncatedBody = post.body ? (post.body.length > 100 ? post.body.slice(0, 100) + '...' : post.body) : 'No description available.';
const author = post.author || 'Unknown Author';
const groupName = post.group_name || post.group_id || 'Facebook Group';
const postDate = formatDate(post.post_date || post.date || post.scraped_at);
let postRouteId = post.facebook_post_id || post.temporary_id;
if (!postRouteId) {
  postRouteId = post.id?.startsWith('http') ? encodeURIComponent(post.id) : post.id;
}
---

<article class="flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-all hover:shadow-md">
  <div class="relative aspect-video w-full overflow-hidden bg-slate-100 border-b border-slate-200">
    <img 
      src={firstImage || '/image (3).png'} 
      alt={author + " post image"} 
      loading="lazy" 
      class="h-full w-full object-cover object-center transition-transform duration-300 hover:scale-105" 
    />
    {imageCount > 1 && (
      <div class="absolute bottom-2 right-2 rounded-md bg-black/70 px-2 py-1 text-xs font-semibold text-white backdrop-blur-sm">
        {imageCount} Photos
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center gap-2 border-b border-slate-100 pb-3">
      <span class="font-semibold text-slate-900 text-sm truncate">{author}</span>
    </div>

    <p class="mt-3 flex-1 text-sm text-slate-600 leading-relaxed line-clamp-3">
      {truncatedBody}
    </p>

    <div class="mt-5 pt-3 border-t border-slate-100">
      <a 
        href={`/posts/${postRouteId}`} 
        class="inline-flex w-full items-center justify-center gap-1 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 transition-colors shadow-sm"
      >
        <span>View Details</span>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
