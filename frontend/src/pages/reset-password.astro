---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Set New Password">
  <div class="flex min-h-[80vh] items-center justify-center">
    <div class="w-full max-w-md rounded-xl bg-white p-8 shadow-sm border border-slate-200">
      <div class="mb-8 text-center">
        <h1 class="text-2xl font-bold text-slate-900">Set New Password</h1>
        <p class="mt-2 text-sm text-slate-600">Please enter your new password below</p>
      </div>

      <!-- Loading State -->
      <div id="loading-state" class="text-center text-slate-600 mb-6">
        <p>Verifying reset link...</p>
      </div>

      <!-- Invalid Link State -->
      <div id="invalid-state" class="hidden text-center">
        <div class="rounded-md bg-red-50 p-4 text-sm text-red-700 mb-6">
          <p>This password reset link is invalid or has expired.</p>
        </div>
        <a href="/forgot-password" class="inline-block w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
          Request another reset link
        </a>
      </div>

      <!-- Form State -->
      <div id="form-state" class="hidden">
        <div id="error-message" class="hidden mb-4 rounded-md bg-red-50 p-4 text-sm text-red-700"></div>
        <div id="success-message" class="hidden mb-4 rounded-md bg-green-50 p-4 text-sm text-green-700"></div>

        <form id="reset-password-form" class="space-y-4">
          <div>
            <label for="password" class="block text-sm font-medium text-slate-700">New Password</label>
            <input type="password" name="password" id="password" required minlength="8" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm placeholder-slate-400 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" />
          </div>

          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-slate-700">Confirm New Password</label>
            <input type="password" name="confirmPassword" id="confirmPassword" required minlength="8" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm placeholder-slate-400 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" />
          </div>

          <button type="submit" id="submit-button" class="w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
            Update Password
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';
    
    // Instantiate browser-only client
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || 'https://gimjsxpwteluwiopcrqq.supabase.co';
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdpbWpzeHB3dGVsdXdpb3BjcnFxIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjM3MjQxNSwiZXhwIjoyMDk3OTQ4NDE1fQ.yOAo3SHHckS1m5R1WK6vGza0IK_Yb2BI0aepjTE5aYM';
    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    const loadingState = document.getElementById('loading-state') as HTMLDivElement;
    const invalidState = document.getElementById('invalid-state') as HTMLDivElement;
    const formState = document.getElementById('form-state') as HTMLDivElement;
    
    const form = document.getElementById('reset-password-form') as HTMLFormElement;
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;
    const successDiv = document.getElementById('success-message') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-button') as HTMLButtonElement;

    async function initializeRecovery() {
      const urlParams = new URLSearchParams(window.location.search);
      const code = urlParams.get('code');
      
      if (code) {
        console.log('[Debug] Exchanging code for session:', code);
        const { data: exchangeData, error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
        
        if (exchangeError) {
          console.error('[Debug] exchangeCodeForSession error:', exchangeError);
        } else {
          console.log('[Debug] exchangeCodeForSession success:', exchangeData);
          // Remove code from URL to prevent reuse
          window.history.replaceState({}, document.title, window.location.pathname);
        }
      }

      console.log('[Debug] Fetching current session...');
      const { data: { session }, error: sessionError } = await supabase.auth.getSession();
      
      loadingState.classList.add('hidden');

      if (sessionError || !session) {
        console.error('[Debug] getSession returned null or error:', sessionError);
        invalidState.classList.remove('hidden');
      } else {
        console.log('[Debug] Valid session established:', session.user.id);
        formState.classList.remove('hidden');
      }
    }

    // Run the initialization immediately
    initializeRecovery();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');
      
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

      if (password !== confirmPassword) {
        errorDiv.textContent = 'Passwords must match.';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      if (password.length < 8) {
        errorDiv.textContent = 'Password must be at least 8 characters.';
        errorDiv.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Updating...';

      console.log('[Debug] Calling updateUser...');
      const { data: updateData, error: updateError } = await supabase.auth.updateUser({ password });

      submitBtn.disabled = false;
      submitBtn.textContent = 'Update Password';

      if (updateError) {
        console.error('[Debug] updateUser error:', updateError);
        errorDiv.textContent = updateError.message;
        errorDiv.classList.remove('hidden');
      } else {
        console.log('[Debug] updateUser success:', updateData);
        successDiv.textContent = 'Password updated successfully.';
        successDiv.classList.remove('hidden');
        form.classList.add('hidden');
        
        console.log('[Debug] Signing out after successful update...');
        await supabase.auth.signOut();
        
        window.location.href = '/login?reset=success';
      }
    });
  </script>
</Layout>
