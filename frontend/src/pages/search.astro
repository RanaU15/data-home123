---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import SkeletonCard from '../components/SkeletonCard.astro';
import { supabase, type Post } from '../lib/supabase';

// Fetch all posts to allow instant client-side search & filtering with pagination
const { data: posts, error } = await supabase
  .from('posts')
  .select('*')
  .order('scraped_at', { ascending: false });

const validPosts = (!error && posts) ? posts : [];

// Extract unique group names for the filter dropdown
const groups = Array.from(new Set(validPosts.map((p: Post) => p.group_name || p.group_id || 'Facebook Group'))).filter(Boolean);
---

<Layout title="Search & Filter Posts | FB Data Inspector">
  <div class="mb-8 border-b border-slate-200 pb-5">
    <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Search & Filter Posts</h1>
    <p class="mt-1 text-sm text-slate-500">Quickly find specific scraped posts by author name, description content, or Facebook group.</p>
  </div>

  <!-- Search & Filter Controls Bar -->
  <div class="mb-8 grid grid-cols-1 md:grid-cols-3 gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div>
      <label for="search-desc" class="block text-xs font-semibold text-slate-700 mb-1.5">Search by Description</label>
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input 
          type="text" 
          id="search-desc" 
          placeholder="Keywords in description..." 
          class="w-full rounded-xl border border-slate-200 bg-slate-50 py-2 pl-9 pr-4 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:bg-white focus:outline-none transition-all"
        />
      </div>
    </div>

    <div>
      <label for="search-author" class="block text-xs font-semibold text-slate-700 mb-1.5">Search by Author</label>
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </span>
        <input 
          type="text" 
          id="search-author" 
          placeholder="Author name..." 
          class="w-full rounded-xl border border-slate-200 bg-slate-50 py-2 pl-9 pr-4 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:bg-white focus:outline-none transition-all"
        />
      </div>
    </div>

    <div>
      <label for="filter-group" class="block text-xs font-semibold text-slate-700 mb-1.5">Filter by Facebook Group</label>
      <select 
        id="filter-group" 
        class="w-full rounded-xl border border-slate-200 bg-slate-50 py-2 px-3 text-sm text-slate-900 focus:border-blue-600 focus:bg-white focus:outline-none transition-all"
      >
        <option value="">All Groups</option>
        {groups.map((g: string) => (
          <option value={g}>{g}</option>
        ))}
      </select>
    </div>
  </div>

  <!-- Skeleton Loader (Shown during search/filtering transitions) -->
  <div id="search-skeleton" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 hidden">
    <SkeletonCard />
    <SkeletonCard />
    <SkeletonCard />
    <SkeletonCard />
    <SkeletonCard />
    <SkeletonCard />
    <SkeletonCard />
    <SkeletonCard />
  </div>

  <!-- Search Results Container -->
  <div id="results-container">
    <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {validPosts.map((post: Post) => (
        <div 
          class="post-filter-wrapper" 
          data-author={(post.author || '').toLowerCase()} 
          data-body={(post.body || '').toLowerCase()} 
          data-group={post.group_name || post.group_id || 'Facebook Group'}
        >
          <PostCard post={post} />
        </div>
      ))}
    </div>

    <!-- Pagination Controls -->
    <div id="pagination-wrapper" class="mt-12 flex items-center justify-between border-t border-slate-200 pt-6">
      <div class="flex flex-1 items-center justify-between sm:hidden">
        <button 
          type="button" 
          id="prev-page-mobile" 
          class="relative inline-flex items-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:pointer-events-none disabled:opacity-50 cursor-pointer"
        >
          Previous
        </button>
        <button 
          type="button" 
          id="next-page-mobile" 
          class="relative ml-3 inline-flex items-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:pointer-events-none disabled:opacity-50 cursor-pointer"
        >
          Next
        </button>
      </div>
      <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
        <div>
          <p class="text-sm text-slate-700">
            Showing <span id="page-from" class="font-medium">1</span> to <span id="page-to" class="font-medium">20</span> of <span id="page-total" class="font-medium">0</span> results
          </p>
        </div>
        <div>
          <nav class="inline-flex items-center gap-2" aria-label="Pagination">
            <button 
              type="button" 
              id="prev-page-btn" 
              class="inline-flex items-center gap-1 rounded-xl border border-slate-200 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 shadow-sm transition-colors disabled:pointer-events-none disabled:opacity-50 cursor-pointer"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              <span>Previous</span>
            </button>

            <span id="page-indicator" class="px-4 py-2 text-sm font-semibold text-slate-700 bg-slate-100 rounded-xl">
              Page 1 of 1
            </span>

            <button 
              type="button" 
              id="next-page-btn" 
              class="inline-flex items-center gap-1 rounded-xl border border-slate-200 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 shadow-sm transition-colors disabled:pointer-events-none disabled:opacity-50 cursor-pointer"
            >
              <span>Next</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </nav>
        </div>
      </div>
    </div>
  </div>

  <!-- Empty State (Shown when no results match filters) -->
  <div id="no-results-state" class="rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center shadow-sm hidden">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-amber-50 text-amber-600">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
    </div>
    <h3 class="mt-4 text-lg font-semibold text-slate-900">No matching posts found</h3>
    <p class="mt-2 text-sm text-slate-500 max-w-sm mx-auto">
      No scraped posts match your current search keywords or group filter. Try adjusting your search parameters.
    </p>
    <button 
      type="button" 
      id="reset-filters-btn" 
      class="mt-6 inline-flex items-center gap-2 rounded-xl bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-slate-800 transition-colors shadow-sm cursor-pointer"
    >
      <span>Reset All Filters</span>
    </button>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const inputDesc = document.getElementById("search-desc") as HTMLInputElement;
      const inputAuthor = document.getElementById("search-author") as HTMLInputElement;
      const selectGroup = document.getElementById("filter-group") as HTMLSelectElement;
      const resultsContainer = document.getElementById("results-container");
      const searchSkeleton = document.getElementById("search-skeleton");
      const noResultsState = document.getElementById("no-results-state");
      const paginationWrapper = document.getElementById("pagination-wrapper");
      const resetBtn = document.getElementById("reset-filters-btn");
      const postWrappers = document.querySelectorAll(".post-filter-wrapper");

      // Pagination elements
      const prevBtn = document.getElementById("prev-page-btn") as HTMLButtonElement;
      const nextBtn = document.getElementById("next-page-btn") as HTMLButtonElement;
      const prevMobile = document.getElementById("prev-page-mobile") as HTMLButtonElement;
      const nextMobile = document.getElementById("next-page-mobile") as HTMLButtonElement;
      const pageIndicator = document.getElementById("page-indicator");
      const pageFrom = document.getElementById("page-from");
      const pageTo = document.getElementById("page-to");
      const pageTotal = document.getElementById("page-total");

      let filterTimeout: any = null;
      let currentPage = 1;
      const pageSize = 20;
      let matchingPosts: HTMLElement[] = [];

      function updatePaginationView() {
        const totalPosts = matchingPosts.length;
        const totalPages = Math.max(1, Math.ceil(totalPosts / pageSize));

        if (currentPage > totalPages) currentPage = totalPages;

        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = Math.min(startIndex + pageSize, totalPosts);

        // Hide all post wrappers first
        postWrappers.forEach(elem => { (elem as HTMLElement).style.display = "none"; });

        // Show only matching posts for the current page
        for (let i = startIndex; i < endIndex; i++) {
          matchingPosts[i].style.display = "";
        }

        // Update UI text and button states
        if (pageFrom) pageFrom.textContent = (totalPosts === 0 ? 0 : startIndex + 1).toString();
        if (pageTo) pageTo.textContent = endIndex.toString();
        if (pageTotal) pageTotal.textContent = totalPosts.toString();
        if (pageIndicator) pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;

        const disablePrev = currentPage <= 1;
        const disableNext = currentPage >= totalPages;

        if (prevBtn) prevBtn.disabled = disablePrev;
        if (prevMobile) prevMobile.disabled = disablePrev;
        if (nextBtn) nextBtn.disabled = disableNext;
        if (nextMobile) nextMobile.disabled = disableNext;

        if (totalPosts > 0) {
          if (resultsContainer) resultsContainer.classList.remove("hidden");
          if (noResultsState) noResultsState.classList.add("hidden");
        } else {
          if (resultsContainer) resultsContainer.classList.add("hidden");
          if (noResultsState) noResultsState.classList.remove("hidden");
        }
      }

      function filterPosts() {
        if (!resultsContainer || !searchSkeleton || !noResultsState) return;

        const descQuery = inputDesc.value.toLowerCase().trim();
        const authorQuery = inputAuthor.value.toLowerCase().trim();
        const groupFilter = selectGroup.value;

        // Show skeleton loader briefly to indicate background filtering
        resultsContainer.classList.add("hidden");
        noResultsState.classList.add("hidden");
        searchSkeleton.classList.remove("hidden");

        if (filterTimeout) clearTimeout(filterTimeout);

        filterTimeout = setTimeout(() => {
          searchSkeleton.classList.add("hidden");
          matchingPosts = [];

          postWrappers.forEach((elem) => {
            const wrapper = elem as HTMLElement;
            const author = wrapper.getAttribute("data-author") || "";
            const body = wrapper.getAttribute("data-body") || "";
            const group = wrapper.getAttribute("data-group") || "";

            const matchesDesc = !descQuery || body.includes(descQuery);
            const matchesAuthor = !authorQuery || author.includes(authorQuery);
            const matchesGroup = !groupFilter || group === groupFilter;

            if (matchesDesc && matchesAuthor && matchesGroup) {
              matchingPosts.push(wrapper);
            }
          });

          // Reset to page 1 on filter change
          currentPage = 1;
          updatePaginationView();
        }, 250);
      }

      // Initial filter run to set up pagination
      filterPosts();

      if (inputDesc) inputDesc.addEventListener("input", filterPosts);
      if (inputAuthor) inputAuthor.addEventListener("input", filterPosts);
      if (selectGroup) selectGroup.addEventListener("change", filterPosts);

      function goToPage(newPage: number) {
        currentPage = newPage;
        updatePaginationView();
        window.scrollTo({ top: 300, behavior: 'smooth' });
      }

      if (prevBtn) prevBtn.addEventListener("click", () => goToPage(currentPage - 1));
      if (prevMobile) prevMobile.addEventListener("click", () => goToPage(currentPage - 1));
      if (nextBtn) nextBtn.addEventListener("click", () => goToPage(currentPage + 1));
      if (nextMobile) nextMobile.addEventListener("click", () => goToPage(currentPage + 1));

      if (resetBtn) {
        resetBtn.addEventListener("click", () => {
          if (inputDesc) inputDesc.value = "";
          if (inputAuthor) inputAuthor.value = "";
          if (selectGroup) selectGroup.value = "";
          filterPosts();
        });
      }
    });
  </script>
</Layout>
