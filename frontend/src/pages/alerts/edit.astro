---
import Layout from '../../layouts/Layout.astro';
import { getUser } from '../../lib/auth';
import { createSupabaseServerClient } from '../../lib/supabase';

const { user } = await getUser(Astro);
if (!user) {
  return Astro.redirect('/login');
}

const alertId = Astro.url.searchParams.get('id');
if (!alertId) {
  return Astro.redirect('/alerts');
}

const supabase = createSupabaseServerClient(Astro);
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = formData.get('name') as string;
  const location = formData.get('location') as string;
  const property_types = formData.getAll('property_types') as string[];
  const tenant_types = formData.getAll('tenant_types') as string[];

  if (!name || name.trim() === '') {
    errorMessage = 'Alert name is required.';
  } else {
    const { error } = await supabase.from('alerts').update({
      name: name.trim(),
      location: location ? location.trim() : null,
      property_types,
      tenant_types
    }).eq('id', alertId).eq('user_id', user.id);

    if (error) {
      errorMessage = error.message;
    } else {
      return Astro.redirect('/alerts');
    }
  }
}

const { data: alert, error: fetchError } = await supabase
  .from('alerts')
  .select('*')
  .eq('id', alertId)
  .eq('user_id', user.id)
  .single();

if (fetchError || !alert) {
  return Astro.redirect('/alerts');
}

const PROPERTY_TYPES = ["1 BHK", "2 BHK", "3 BHK", "4 BHK"];
const TENANT_TYPES = ["Bachelor", "Family"];
---

<Layout title="Edit Alert | Data Inspector">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8 flex items-center gap-4">
      <a href="/alerts" class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Edit Alert</h1>
        <p class="text-slate-500 text-sm mt-1">Update your keywords and location.</p>
      </div>
    </div>

    {errorMessage && (
      <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg mb-6 text-sm">
        {errorMessage}
      </div>
    )}

    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 sm:p-8">
      <form method="POST" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-semibold text-slate-900 mb-1">Alert Name</label>
          <input type="text" name="name" id="name" required value={alert.name} class="w-full rounded-xl border border-slate-300 bg-white px-4 py-2 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all">
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-900 mb-2">Property Type <span class="text-slate-500 font-normal">(Optional)</span></label>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {PROPERTY_TYPES.map(pt => (
              <label class="relative flex cursor-pointer rounded-xl border border-slate-200 bg-white p-3 shadow-sm hover:bg-slate-50 focus-within:ring-2 focus-within:ring-blue-500 transition-colors">
                <input type="checkbox" name="property_types" value={pt} checked={alert.property_types?.includes(pt)} class="sr-only peer" />
                <div class="flex flex-col">
                  <span class="text-sm font-medium text-slate-900 peer-checked:text-blue-700">{pt}</span>
                </div>
                <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 pointer-events-none transition-colors"></div>
                <svg class="absolute top-3 right-3 h-5 w-5 text-blue-600 opacity-0 peer-checked:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-900 mb-2">Tenant Type <span class="text-slate-500 font-normal">(Optional)</span></label>
          <div class="grid grid-cols-2 gap-3">
            {TENANT_TYPES.map(tt => (
              <label class="relative flex cursor-pointer rounded-xl border border-slate-200 bg-white p-3 shadow-sm hover:bg-slate-50 focus-within:ring-2 focus-within:ring-blue-500 transition-colors">
                <input type="checkbox" name="tenant_types" value={tt} checked={alert.tenant_types?.includes(tt)} class="sr-only peer" />
                <div class="flex flex-col">
                  <span class="text-sm font-medium text-slate-900 peer-checked:text-indigo-700">{tt}</span>
                </div>
                <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-indigo-600 pointer-events-none transition-colors"></div>
                <svg class="absolute top-3 right-3 h-5 w-5 text-indigo-600 opacity-0 peer-checked:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label for="location" class="block text-sm font-semibold text-slate-900 mb-1">Location <span class="text-slate-500 font-normal">(Optional)</span></label>
          <input type="text" name="location" id="location" value={alert.location || ''} placeholder="e.g. Rajkot, Satellite, Ahmedabad" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-2 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-50 transition-all">
          <p class="text-xs text-slate-500 mt-2">Enter a city or area name to filter posts containing this location.</p>
        </div>

        <div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-3">
          <a href="/alerts" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">Cancel</a>
          <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors">
            Update Alert
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>
