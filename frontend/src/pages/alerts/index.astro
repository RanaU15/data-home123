---
import Layout from '../../layouts/Layout.astro';
import { getUser } from '../../lib/auth';
import { createSupabaseServerClient } from '../../lib/supabase';

const { user } = await getUser(Astro);
if (!user) {
  return Astro.redirect('/login');
}

const supabase = createSupabaseServerClient(Astro);

// Handle toggle and delete
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  const alertId = formData.get('alert_id');

  if (action === 'toggle' && alertId) {
    const { data: current } = await supabase.from('alerts').select('enabled').eq('id', alertId).eq('user_id', user.id).single();
    if (current) {
      await supabase.from('alerts').update({ enabled: !current.enabled }).eq('id', alertId).eq('user_id', user.id);
    }
  } else if (action === 'delete' && alertId) {
    await supabase.from('alerts').delete().eq('id', alertId).eq('user_id', user.id);
  }
  
  return Astro.redirect('/alerts');
}

const { data: alerts, error } = await supabase
  .from('alerts')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

---

<Layout title="My Alerts | Data Inspector">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Keyword Alerts</h1>
        <p class="text-slate-500 text-sm mt-1">Get notified when new Facebook posts match your keywords.</p>
      </div>
      <a href="/alerts/create" class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Create Alert
      </a>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg mb-6">
        Failed to load alerts: {error.message}
      </div>
    )}

    {!alerts || alerts.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center shadow-sm">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-blue-50 text-blue-600 mb-4">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900">No alerts yet</h3>
        <p class="text-sm text-slate-500 mt-1 mb-6">Create an alert to get notified about specific properties.</p>
        <a href="/alerts/create" class="inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 transition-colors">
          Create Your First Alert
        </a>
      </div>
    ) : (
      <div class="grid gap-4">
        {alerts.map((alert) => (
          <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex-1 min-w-0 pr-4">
              <div class="flex items-center gap-3 mb-1">
                <h3 class="text-lg font-semibold text-slate-900 truncate">{alert.name}</h3>
                <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${alert.enabled ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-600'}`}>
                  {alert.enabled ? 'Active' : 'Disabled'}
                </span>
              </div>
              <div class="flex flex-wrap gap-2 mt-2">
                {alert.property_types && alert.property_types.map((type: string) => (
                  <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                    {type}
                  </span>
                ))}
                {alert.tenant_types && alert.tenant_types.map((type: string) => (
                  <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                    {type}
                  </span>
                ))}
                {alert.location && (
                  <span class="inline-flex items-center rounded-md bg-amber-50 px-2 py-1 text-xs font-medium text-amber-800 ring-1 ring-inset ring-amber-600/20">
                    📍 {alert.location}
                  </span>
                )}
              </div>
            </div>
            
            <div class="flex items-center gap-3">
              <form method="POST" class="inline">
                <input type="hidden" name="action" value="toggle" />
                <input type="hidden" name="alert_id" value={alert.id} />
                <button type="submit" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">
                  {alert.enabled ? 'Disable' : 'Enable'}
                </button>
              </form>
              <div class="w-px h-4 bg-slate-200"></div>
              <a href={`/alerts/edit?id=${alert.id}`} class="text-sm font-medium text-blue-600 hover:text-blue-500 transition-colors">Edit</a>
              <div class="w-px h-4 bg-slate-200"></div>
              <form method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this alert?');">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="alert_id" value={alert.id} />
                <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-500 transition-colors">
                  Delete
                </button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
