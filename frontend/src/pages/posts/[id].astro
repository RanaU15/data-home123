---
import Layout from '../../layouts/Layout.astro';
import { supabase, parseImages, getDisplayDate, parseVideoUrls, type Post } from '../../lib/supabase';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const cleanId = decodeURIComponent(id || '');

// First try querying by facebook_post_id
let { data: postData, error } = await supabase
  .from('posts')
  .select('*')
  .eq('facebook_post_id', cleanId)
  .limit(1)
  .single();

if (!postData) {
  // Try querying by id
  const { data: dataById } = await supabase
    .from('posts')
    .select('*')
    .eq('id', cleanId)
    .limit(1)
    .single();
  postData = dataById;
}

if (!postData) {
  // Try querying by temporary_id
  const { data: dataByTemp } = await supabase
    .from('posts')
    .select('*')
    .eq('temporary_id', cleanId)
    .limit(1)
    .single();
  postData = dataByTemp;
}

const post: Post | null = postData || null;

let images: string[] = [];
let author = 'Unknown Author';
let groupName = 'Facebook Group';
let postDate = 'Unknown Date';
let permalink = '#';
let body = '';
let imageCount = 0;

if (post) {
  images = post.image_urls || [];
  if (images.length === 0 && post.images) {
    let oldImages = Array.isArray(post.images) ? post.images : [];
    if (typeof post.images === 'string') {
      try { oldImages = JSON.parse(post.images); } catch(e) {}
    }
    images = oldImages.filter((img: string) => !img.includes('supabase.co'));
  }
  author = post.author || 'Unknown Author';
  groupName = post.group_name || post.group_id || 'Facebook Group';
  postDate = getDisplayDate(post);
  
  const parsedVideos = parseVideoUrls(post.video_urls);
  post.video_urls = parsedVideos;
  
  permalink = post.post_url || post.permalink || '';
  if (!permalink.startsWith('http')) {
    if (post.facebook_post_id && post.facebook_post_id !== 'N/A') {
      permalink = `https://www.facebook.com/${post.facebook_post_id}`;
    } else {
      permalink = '';
    }
  }

  body = post.body || 'No description available for this post.';
  imageCount = images.length;
}
---

<Layout title={post ? `${author} - Post Details | FB Data Inspector` : 'Post Not Found | FB Data Inspector'}>
  <div class="mb-6">
    <a href="/" class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Back to all posts</span>
    </a>
  </div>

  {!post ? (
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center shadow-sm max-w-2xl mx-auto my-12">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-rose-50 text-rose-600">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
      </div>
      <h2 class="mt-4 text-2xl font-bold text-slate-900">Post Not Found (404)</h2>
      <p class="mt-2 text-sm text-slate-500 max-w-md mx-auto">
        The requested post with ID <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-700 font-mono">{id}</code> could not be found in the Supabase database. It may have been removed or the ID is incorrect.
      </p>
      <div class="mt-8">
        <a href="/" class="inline-flex items-center gap-2 rounded-xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white hover:bg-slate-800 transition-colors shadow-sm">
          <span>Browse All Scraped Posts</span>
        </a>
      </div>
    </div>
  ) : (
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Left Column: Image Gallery -->
      <div class="lg:col-span-7 space-y-4">
        {post?.has_video || post?.facebook_video_url ? (
          <div class="overflow-hidden rounded-2xl bg-slate-100 aspect-video relative group border border-slate-200 flex items-center justify-center">
            {(post.video_thumbnail || (images.length > 0 ? images[0] : null)) ? (
              <img src={post.video_thumbnail || images[0]} referrerpolicy="no-referrer" alt="Video Thumbnail" class="absolute inset-0 w-full h-full object-cover opacity-80" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center bg-slate-100 text-slate-400">
                <span class="font-medium text-lg uppercase tracking-wider text-slate-300">No Thumbnail</span>
              </div>
            )}
            <a href={post.facebook_video_url || permalink} target="_blank" rel="noopener noreferrer" class="relative z-10 flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3.5 rounded-full font-bold transition-colors shadow-lg shadow-blue-600/30">
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
              Watch Video on Facebook
            </a>
          </div>
        ) : (
          <div class="rounded-2xl border border-slate-200 bg-white shadow-sm flex flex-col overflow-hidden">
            {images.length > 0 ? (
              <>
                <div class="relative w-full aspect-[4/3] sm:aspect-video bg-slate-50 flex items-center justify-center group select-none overflow-hidden" id="main-image-container">
                  <!-- Skeleton loader -->
                  <div id="image-loader" class="absolute inset-0 flex items-center justify-center bg-slate-50 z-10">
                     <svg class="animate-spin h-8 w-8 text-slate-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                  </div>

                  <img 
                    id="main-gallery-image"
                    src={images[0]} 
                    alt={`${author} post image 1`} 
                    class="w-full h-full object-contain cursor-zoom-in transition-opacity duration-300 opacity-0 relative z-20"
                    onload="this.classList.remove('opacity-0'); document.getElementById('image-loader').style.display='none';"
                    referrerpolicy="no-referrer"
                    data-index="0"
                  />

                  <!-- Image Counter -->
                  <div class="absolute top-4 left-4 z-30 bg-black/60 backdrop-blur-md text-white text-xs font-semibold px-3 py-1.5 rounded-full shadow-sm pointer-events-none">
                    <span id="gallery-counter">Image 1 of {imageCount}</span>
                  </div>
                  
                  <!-- Fullscreen button -->
                  <button type="button" id="open-lightbox-btn" class="absolute top-4 right-4 z-30 bg-black/60 hover:bg-black/80 backdrop-blur-md text-white p-2 rounded-full transition-colors shadow-sm" title="Fullscreen">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" /></svg>
                  </button>

                  <!-- Navigation Arrows -->
                  {imageCount > 1 && (
                    <>
                      <button type="button" id="prev-image-btn" class="absolute left-3 top-1/2 -translate-y-1/2 z-30 bg-white/90 hover:bg-white text-slate-800 p-2 rounded-full shadow-md transition-all opacity-0 group-hover:opacity-100 focus:opacity-100" title="Previous Image">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                      </button>
                      <button type="button" id="next-image-btn" class="absolute right-3 top-1/2 -translate-y-1/2 z-30 bg-white/90 hover:bg-white text-slate-800 p-2 rounded-full shadow-md transition-all opacity-0 group-hover:opacity-100 focus:opacity-100" title="Next Image">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                      </button>
                    </>
                  )}
                </div>
                
                {imageCount > 1 && (
                  <div class="w-full bg-white p-4 border-t border-slate-100">
                    <div class="flex overflow-x-auto gap-3 pb-2 scrollbar-hide snap-x" id="thumbnail-container">
                      {images.map((url: string, idx: number) => (
                        <button 
                          type="button" 
                          class={`gallery-thumbnail flex-shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-lg overflow-hidden snap-center focus:outline-none transition-all ${idx === 0 ? 'ring-2 ring-blue-600 border-2 border-transparent opacity-100' : 'opacity-60 hover:opacity-100 border-2 border-transparent'}`}
                          data-image={url}
                          data-index={idx}
                          aria-label={`View image ${idx + 1}`}
                        >
                          <img 
                            src={url} 
                            alt={`Thumbnail ${idx + 1}`} 
                            class="w-full h-full object-cover" 
                            referrerpolicy="no-referrer"
                            loading="lazy"
                          />
                        </button>
                      ))}
                    </div>
                  </div>
                )}
              </>
            ) : (
              <div class="flex flex-col items-center justify-center text-slate-400 aspect-video bg-slate-50">
                <svg class="w-20 h-20 mb-4 opacity-20" fill="currentColor" viewBox="0 0 24 24"><path d="M4 4h16v16H4z" opacity="0.2"/><path d="M4 2h16c1.1 0 2 .9 2 2v16c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2zm0 18h16V4H4v16zm11-11a2 2 0 110-4 2 2 0 010 4zM5.5 17h13l-4-5-3.5 4.5-2.5-3L5.5 17z"/></svg>
                <span class="font-medium text-lg uppercase tracking-wider text-slate-300">No Image</span>
              </div>
            )}
          </div>
        )}

        {/* Thumbnails grid removed as requested to display only clickable links */}
      </div>

      <!-- Right Column: Details & Metadata -->
      <div class="lg:col-span-5 flex flex-col space-y-6">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex-1 flex flex-col">
          <div class="flex items-center gap-4 border-b border-slate-100 pb-4">
            {post?.author_avatar && (
              <img src={post.author_avatar} referrerpolicy="no-referrer" alt={author} class="w-12 h-12 rounded-full object-cover bg-slate-100 border border-slate-200" />
            )}
            <div class="flex-1">
              <a href={post?.author_profile_url || '#'} target={post?.author_profile_url ? '_blank' : '_self'} class="font-bold text-slate-900 text-lg hover:text-blue-600 transition-colors">{author}</a>
              <div class="text-xs text-slate-500 font-medium mt-0.5">{postDate}</div>
            </div>
            <span class="inline-flex items-center rounded-lg bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700 border border-blue-200/60">
              {groupName}
            </span>
          </div>



          <!-- Description -->
          <div class="mt-6 flex-1">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Full Post Text</h3>
            <p class="text-slate-700 text-sm leading-relaxed whitespace-pre-line">
              {body}
            </p>
          </div>

          <!-- Action Buttons -->
          <div class="mt-6 grid grid-cols-2 gap-3 border-t border-slate-100 pt-6">
            {permalink ? (
              <a 
                href={permalink} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-500 transition-colors shadow-sm text-center"
              >
                <span>Open on Facebook</span>
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ) : post?.group_url ? (
              <a 
                href={post.group_url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-500 transition-colors shadow-sm text-center"
              >
                <span>Open Facebook Group</span>
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ) : (
              <button 
                disabled
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-slate-200 px-4 py-3 text-sm font-semibold text-slate-400 cursor-not-allowed shadow-sm text-center"
              >
                <span>No Post URL</span>
              </button>
            )}

            {permalink ? (
              <button 
                type="button" 
                id="copy-url-btn" 
                data-url={permalink} 
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-slate-100 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-200 transition-colors shadow-sm text-center cursor-pointer"
              >
                <svg id="copy-icon-default" class="h-4 w-4 flex-shrink-0 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                <svg id="copy-icon-success" class="h-4 w-4 flex-shrink-0 text-emerald-600 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span id="copy-text">Copy URL</span>
              </button>
            ) : post?.group_url ? (
              <button 
                type="button" 
                id="copy-url-btn" 
                data-url={post.group_url} 
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-slate-100 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-200 transition-colors shadow-sm text-center cursor-pointer"
              >
                <svg id="copy-icon-default" class="h-4 w-4 flex-shrink-0 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                <svg id="copy-icon-success" class="h-4 w-4 flex-shrink-0 text-emerald-600 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span id="copy-text">Copy Group URL</span>
              </button>
            ) : (
              <button 
                disabled
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-slate-100 px-4 py-3 text-sm font-semibold text-slate-400 cursor-not-allowed shadow-sm text-center"
              >
                <span>No Post URL</span>
              </button>
            )}
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex-col items-center justify-center backdrop-blur-sm touch-none">
    <div class="absolute top-4 right-4 z-10 flex gap-4">
      <div id="lightbox-counter" class="text-white text-sm font-medium bg-black/50 px-3 py-1.5 rounded-full backdrop-blur">Image 1 of {imageCount}</div>
      <button id="lightbox-close" class="text-white hover:text-slate-300 p-1 rounded-full bg-black/50 hover:bg-black/70 backdrop-blur transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
    
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white p-3 rounded-full bg-black/50 hover:bg-black/80 backdrop-blur transition-colors z-10">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
    </button>
    
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white p-3 rounded-full bg-black/50 hover:bg-black/80 backdrop-blur transition-colors z-10">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </button>
    
    <img id="lightbox-img" src="" alt="Fullscreen image" class="max-h-screen max-w-full object-contain pointer-events-none select-none transition-opacity duration-200" />
  </div>

  <script id="images-data" type="application/json" set:html={JSON.stringify(images)}></script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // --- Image Gallery Logic ---
      const imagesDataEl = document.getElementById('images-data');
      if (imagesDataEl) {
        const imagesList = JSON.parse(imagesDataEl.textContent || '[]');
        
        if (imagesList.length > 0) {
          let currentIndex = 0;
          const mainImg = document.getElementById("main-gallery-image") as HTMLImageElement;
          const loader = document.getElementById("image-loader");
          const counter = document.getElementById("gallery-counter");
          const thumbnails = document.querySelectorAll(".gallery-thumbnail");
          
          const lightbox = document.getElementById("lightbox");
          const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
          const lightboxCounter = document.getElementById("lightbox-counter");
          
          function updateGallery(index: number) {
            if (index < 0) index = imagesList.length - 1;
            if (index >= imagesList.length) index = 0;
            currentIndex = index;
            
            const newSrc = imagesList[currentIndex];
            
            if (mainImg && mainImg.src !== newSrc) {
              if (loader) loader.style.display = 'flex';
              mainImg.classList.add('opacity-0');
              mainImg.src = newSrc;
              mainImg.setAttribute('data-index', currentIndex.toString());
            }
            
            if (counter) counter.textContent = `Image ${currentIndex + 1} of ${imagesList.length}`;
            
            thumbnails.forEach((t) => {
              const tIdx = parseInt(t.getAttribute("data-index") || "0", 10);
              if (tIdx === currentIndex) {
                t.classList.remove("opacity-60", "border-transparent");
                t.classList.add("ring-2", "ring-blue-600", "opacity-100");
                t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
              } else {
                t.classList.add("opacity-60", "border-transparent");
                t.classList.remove("ring-2", "ring-blue-600", "opacity-100");
              }
            });
            
            if (lightbox && !lightbox.classList.contains("hidden") && lightboxImg) {
              lightboxImg.classList.add("opacity-50");
              lightboxImg.src = newSrc;
              lightboxImg.onload = () => lightboxImg.classList.remove("opacity-50");
              if (lightboxCounter) lightboxCounter.textContent = `Image ${currentIndex + 1} of ${imagesList.length}`;
            }
            
            // preload next and prev
            if (imagesList.length > 1) {
              const nextIdx = (currentIndex + 1) % imagesList.length;
              const prevIdx = (currentIndex - 1 + imagesList.length) % imagesList.length;
              new Image().src = imagesList[nextIdx];
              new Image().src = imagesList[prevIdx];
            }
          }

          thumbnails.forEach((btn) => {
            btn.addEventListener("click", (e) => {
              const target = e.currentTarget as HTMLElement;
              const idx = parseInt(target.getAttribute("data-index") || "0", 10);
              updateGallery(idx);
            });
          });

          document.getElementById("prev-image-btn")?.addEventListener("click", (e) => { e.stopPropagation(); updateGallery(currentIndex - 1); });
          document.getElementById("next-image-btn")?.addEventListener("click", (e) => { e.stopPropagation(); updateGallery(currentIndex + 1); });
          
          document.getElementById("lightbox-prev")?.addEventListener("click", (e) => { e.stopPropagation(); updateGallery(currentIndex - 1); });
          document.getElementById("lightbox-next")?.addEventListener("click", (e) => { e.stopPropagation(); updateGallery(currentIndex + 1); });
          
          const openLightbox = () => {
            if (!lightbox || imagesList.length === 0) return;
            lightbox.classList.remove("hidden");
            lightbox.classList.add("flex");
            document.body.style.overflow = "hidden";
            updateGallery(currentIndex);
          };
          
          document.getElementById("open-lightbox-btn")?.addEventListener("click", openLightbox);
          if (mainImg) mainImg.addEventListener("click", openLightbox);
          
          const closeLightbox = () => {
            if (!lightbox) return;
            lightbox.classList.add("hidden");
            lightbox.classList.remove("flex");
            document.body.style.overflow = "";
          };
          
          document.getElementById("lightbox-close")?.addEventListener("click", closeLightbox);
          lightbox?.addEventListener("click", (e) => {
            if (e.target === lightbox) closeLightbox();
          });

          document.addEventListener("keydown", (e) => {
            if (!lightbox?.classList.contains("hidden")) {
              if (e.key === "Escape") closeLightbox();
              if (e.key === "ArrowLeft") updateGallery(currentIndex - 1);
              if (e.key === "ArrowRight") updateGallery(currentIndex + 1);
            } else {
              if (e.key === "ArrowLeft") updateGallery(currentIndex - 1);
              if (e.key === "ArrowRight") updateGallery(currentIndex + 1);
            }
          });

          let touchStartX = 0;
          let touchEndX = 0;
          
          const handleSwipe = () => {
            const swipeThreshold = 50;
            if (touchEndX < touchStartX - swipeThreshold) updateGallery(currentIndex + 1);
            if (touchEndX > touchStartX + swipeThreshold) updateGallery(currentIndex - 1);
          };
          
          const mainContainer = document.getElementById("main-image-container");
          if (mainContainer) {
            mainContainer.addEventListener("touchstart", e => touchStartX = e.changedTouches[0].screenX, {passive: true});
            mainContainer.addEventListener("touchend", e => { touchEndX = e.changedTouches[0].screenX; handleSwipe(); }, {passive: true});
          }
          if (lightbox) {
            lightbox.addEventListener("touchstart", e => touchStartX = e.changedTouches[0].screenX, {passive: true});
            lightbox.addEventListener("touchend", e => { touchEndX = e.changedTouches[0].screenX; handleSwipe(); }, {passive: true});
          }
        }
      }

      // Copy URL button handler
      const copyBtn = document.getElementById("copy-url-btn");
      const copyText = document.getElementById("copy-text");
      const iconDefault = document.getElementById("copy-icon-default");
      const iconSuccess = document.getElementById("copy-icon-success");

      if (copyBtn && copyText && iconDefault && iconSuccess) {
        copyBtn.addEventListener("click", async () => {
          const url = copyBtn.getAttribute("data-url") || "";
          try {
            await navigator.clipboard.writeText(url);
            copyText.textContent = "Copied!";
            iconDefault.classList.add("hidden");
            iconSuccess.classList.remove("hidden");
            copyBtn.classList.remove("bg-slate-100", "text-slate-700");
            copyBtn.classList.add("bg-emerald-50", "text-emerald-700", "border", "border-emerald-200");

            setTimeout(() => {
              copyText.textContent = "Copy URL";
              iconDefault.classList.remove("hidden");
              iconSuccess.classList.add("hidden");
              copyBtn.classList.remove("bg-emerald-50", "text-emerald-700", "border", "border-emerald-200");
              copyBtn.classList.add("bg-slate-100", "text-slate-700");
            }, 2000);
          } catch (err) {
            console.error("Failed to copy URL:", err);
          }
        });
      }
    });
  </script>
</Layout>
